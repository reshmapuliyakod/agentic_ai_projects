## 1. Upload and index a PDF document
import requests, time, os

# --- Option A: index from a URL (PageIndex downloads it for you) ---
PDF_URL = "https://arxiv.org/pdf/2501.12948.pdf"  # DeepSeek-R1 paper

result = pi_client.submit_document(PDF_URL)
doc_id = result["doc_id"]
print(f"Submitted document. doc_id = {doc_id}")

# --- Option B: index from a local file ---
# result = pi_client.submit_document("./my_document.pdf")
# doc_id = result["doc_id"]
### 1.1 Wait for processing to complete
print("Waiting for PageIndex to build the tree...", end="")
while True:
    status = pi_client.get_document(doc_id)["status"]
    if status == "completed":
        print(" done!")
        break
    elif status == "failed":
        raise RuntimeError("Document processing failed.")
    else:
        print(".", end="", flush=True)
        time.sleep(5)
### 1.2 Inspect the generated tree
tree = pi_client.get_tree(doc_id)["result"]

# Pretty-print the top-level structure
tree_str = utils.tree_to_string(tree)
print(tree_str[:3000], "..." if len(tree_str) > 3000 else "")
