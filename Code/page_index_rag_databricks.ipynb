llm_client = AsyncOpenAI(
    api_key=DATABRICKS_TOKEN,
    base_url=f"{DATABRICKS_HOST.rstrip('/')}/serving-endpoints",
)

print(f"LLM endpoint : {DATABRICKS_HOST}/serving-endpoints")
print(f"Model        : {DATABRICKS_MODEL}")
