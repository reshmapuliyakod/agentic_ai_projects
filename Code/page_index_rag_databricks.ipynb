## 1. Upload and index a PDF document
import time

# --- Option A: Submit from a public URL ---
PDF_URL = "https://arxiv.org/pdf/2501.12948.pdf"   # DeepSeek-R1 paper
result  = pi_client.submit_document(PDF_URL)
doc_id  = result["doc_id"]
print(f"Submitted. doc_id = {doc_id}")

# --- Option B: Upload from DBFS or local path ---
# result = pi_client.submit_document("/dbfs/mnt/my-data/report.pdf")
# doc_id = result["doc_id"]
### 1.1 Wait for tree generation to complete
print("Building tree index", end="")
while True:
    status = pi_client.get_document(doc_id)["status"]
    if status == "completed":
        print(" ✓ done")
        break
    elif status == "failed":
        raise RuntimeError("PageIndex processing failed.")
    else:
        print(".", end="", flush=True)
        time.sleep(5)
### 1.2 Inspect the tree
tree     = pi_client.get_tree(doc_id)["result"]
tree_str = utils.tree_to_string(tree)
print(tree_str[:3000], "..." if len(tree_str) > 3000 else "")
