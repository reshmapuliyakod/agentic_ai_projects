ANSWER_SYSTEM_PROMPT = """\
You are a helpful document analyst.
Answer the user's question based ONLY on the provided document context.
Be concise and precise. Cite section titles when relevant.
If the context does not contain the answer, say so clearly.
"""

async def pageindex_rag(query: str, doc_id: str, tree: dict) -> str:
    """
    Full PageIndex RAG pipeline using Databricks Foundation Model APIs.

    Steps:
      1. Databricks LLM reasons over tree → selects node_ids
      2. PageIndex fetches text for those nodes
      3. Databricks LLM generates the final answer
    """
    print(f"\n{'='*60}")
    print(f"Query: {query}")
    print('='*60)

    # Step 1: Reason over tree with Databricks LLM
    print("\n[1/3] Reasoning over tree structure...")
    retrieval_result = await retrieve_relevant_nodes(query, tree)
    node_ids  = retrieval_result["node_ids"]
    reasoning = retrieval_result.get("reasoning", "")
    print(f"  Selected nodes : {node_ids}")
    print(f"  Reasoning      : {reasoning}")

    # Step 2: Fetch context from PageIndex
    print("\n[2/3] Fetching node content from PageIndex...")
    context_chunks = []
    for node_id in node_ids:
        try:
            node_content = pi_client.retrieve_context(
                doc_id=doc_id,
                node_id=node_id,
            )
            if node_content and node_content.get("text"):
                title = node_content.get("title", node_id)
                text  = node_content["text"]
                context_chunks.append(f"### {title}\n{text}")
                print(f"  Retrieved '{title}' ({len(text)} chars)")
        except Exception as e:
            print(f"  Warning: could not retrieve node {node_id}: {e}")

    if not context_chunks:
        return "Could not retrieve relevant context for this query."

    combined_context = "\n\n".join(context_chunks)

    # Step 3: Generate answer with Databricks LLM
    print("\n[3/3] Generating answer with Databricks LLM...")
    response = await llm_client.chat.completions.create(
        model=DATABRICKS_MODEL,
        messages=[
            {"role": "system", "content": ANSWER_SYSTEM_PROMPT},
            {
                "role": "user",
                "content": f"Document context:\n\n{combined_context}\n\n---\n\nQuestion: {query}",
            },
        ],
        temperature=0.2,
        max_tokens=1024,
    )

    answer = response.choices[0].message.content.strip()
    print("\n" + "-"*60)
    print("Answer:")
    print(answer)
    print("-"*60)
    return answer


print("RAG pipeline ready.")
