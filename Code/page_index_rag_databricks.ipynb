## 2. Reasoning-based retrieval with a Databricks LLM

The LLM sees the tree structure and decides which `node_id`s are most relevant to the query.
PageIndex then fetches the actual content for those nodes.
import json, asyncio

RETRIEVAL_SYSTEM_PROMPT = """\
You are an expert document navigator.
You are given a hierarchical tree index of a document and a user query.
Identify which sections are most relevant to answer the query.

Return ONLY a valid JSON object — no markdown, no explanation:
{
  "node_ids": ["0001", "0005"],
  "reasoning": "Brief explanation of why these sections are relevant"
}

Rules:
- Select 1-5 node_ids most relevant to the query
- Use the exact 4-digit node_id strings from the tree (e.g. "0001")
- Prefer specific child nodes over broad parent nodes when possible
"""

async def retrieve_relevant_nodes(query: str, tree: dict) -> dict:
    """Use Databricks LLM to reason over the tree and select relevant node IDs."""
    tree_str = utils.tree_to_string(tree)

    user_message = f"""Document tree structure:
```
{tree_str}
```

User query: {query}

Which node_ids are most relevant to answer this query?"""

    response = await llm_client.chat.completions.create(
        model=DATABRICKS_MODEL,
        messages=[
            {"role": "system", "content": RETRIEVAL_SYSTEM_PROMPT},
            {"role": "user",   "content": user_message},
        ],
        temperature=0.0,
        max_tokens=512,
    )

    raw = response.choices[0].message.content.strip()
    # Strip markdown fences some models add
    raw = raw.removeprefix("```json").removeprefix("```").removesuffix("```").strip()
    return json.loads(raw)


print("Retrieval function ready.")
---
## 3. Full RAG pipeline
ANSWER_SYSTEM_PROMPT = """\
You are a helpful document analyst.
Answer the user's question based ONLY on the provided document context.
Be concise and precise. Cite section titles when relevant.
If the context does not contain the answer, say so clearly.
"""

async def pageindex_rag(query: str, doc_id: str, tree: dict) -> str:
    """
    Full PageIndex RAG pipeline using Databricks Foundation Model APIs.

    Steps:
      1. Databricks LLM reasons over tree → selects node_ids
      2. PageIndex fetches text for those nodes
      3. Databricks LLM generates the final answer
    """
    print(f"\n{'='*60}")
    print(f"Query: {query}")
    print('='*60)

    # Step 1: Reason over tree with Databricks LLM
    print("\n[1/3] Reasoning over tree structure...")
    retrieval_result = await retrieve_relevant_nodes(query, tree)
    node_ids  = retrieval_result["node_ids"]
    reasoning = retrieval_result.get("reasoning", "")
    print(f"  Selected nodes : {node_ids}")
    print(f"  Reasoning      : {reasoning}")

    # Step 2: Fetch context from PageIndex
    print("\n[2/3] Fetching node content from PageIndex...")
    context_chunks = []
    for node_id in node_ids:
        try:
            node_content = pi_client.retrieve_context(
                doc_id=doc_id,
                node_id=node_id,
            )
            if node_content and node_content.get("text"):
                title = node_content.get("title", node_id)
                text  = node_content["text"]
                context_chunks.append(f"### {title}\n{text}")
                print(f"  Retrieved '{title}' ({len(text)} chars)")
        except Exception as e:
            print(f"  Warning: could not retrieve node {node_id}: {e}")

    if not context_chunks:
        return "Could not retrieve relevant context for this query."

    combined_context = "\n\n".join(context_chunks)

    # Step 3: Generate answer with Databricks LLM
    print("\n[3/3] Generating answer with Databricks LLM...")
    response = await llm_client.chat.completions.create(
        model=DATABRICKS_MODEL,
        messages=[
            {"role": "system", "content": ANSWER_SYSTEM_PROMPT},
            {
                "role": "user",
                "content": f"Document context:\n\n{combined_context}\n\n---\n\nQuestion: {query}",
            },
        ],
        temperature=0.2,
        max_tokens=1024,
    )

    answer = response.choices[0].message.content.strip()
    print("\n" + "-"*60)
    print("Answer:")
    print(answer)
    print("-"*60)
    return answer


print("RAG pipeline ready.")
---
## 4. Run a query
query = "What reinforcement learning algorithm did DeepSeek-R1 use, and why?"

answer = await pageindex_rag(query, doc_id, tree)
---
## 5. Batch queries
queries = [
    "What are the key benchmark results reported for DeepSeek-R1?",
    "How does DeepSeek-R1 compare to OpenAI-o1?",
    "What is the distillation approach used in the paper?",
]

for q in queries:
    await pageindex_rag(q, doc_id, tree)
    print()
