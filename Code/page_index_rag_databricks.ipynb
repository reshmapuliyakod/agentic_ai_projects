DATABRICKS_MODEL = "databricks-meta-llama-3-3-70b-instruct"
### 0.2 Initialise PageIndex client
from pageindex import PageIndexClient
import pageindex.utils as utils

pi_client = PageIndexClient(api_key=PAGEINDEX_API_KEY)
### 0.3a Initialise LLM client — plain OpenAI SDK pointed at Databricks

Use this approach when running **outside** a Databricks cluster (e.g. local Jupyter, VS Code, Colab).
